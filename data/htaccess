# Disable cache for _list.json (because the list and levels are all json files)
<FilesMatch "\.json$">
    Header set Cache-Control "no-store, must-revalidate"
</FilesMatch>

# Disable cache for List.js (because the rules are there)
<Files "List.js">
    Header set Cache-Control "no-store, must-revalidate"
</Files>